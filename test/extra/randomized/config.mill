package build.test.extra.randomized

object RandomizedTest {
  // first deterministic seed included in the run
  val startSeed = 0
  // number of deterministic seeds to execute
  val seedCount = 10000
  // operation count for each seed unless a test provides a smaller default
  val operations = 3000
  // number of seeds grouped into one JUnit parameterized invocation
  val chunkSize = 100
  // seed-progress logging interval; use 0 to disable progress logs
  val progressEvery = 100
}
