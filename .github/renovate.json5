{
  $schema: "https://docs.renovatebot.com/renovate-schema.json",

  extends: [
    "config:recommended",
    "helpers:pinGitHubActionDigests",
  ],

  customManagers: [
    // Update Maven dependencies written as Mill mvn"...:version" literals.
    {
      customType: "regex",
      managerFilePatterns: ["\\.mill$"],
      matchStrings: [
        'mvn"(?<depName>[^:"]+:[^:"]+):(?<currentValue>[^"]+)"',
      ],
      datasourceTemplate: "maven",
    },
    // Update Maven dependencies stored in plain strings with Renovate hints.
    {
      customType: "regex",
      managerFilePatterns: ["\\.mill$"],
      matchStrings: [
        "val\\s+\\w+\\s*=\\s*\"(?<currentValue>[^\"]+)\"\\s*//\\s*renovate:\\s*depName=(?<depName>\\S+)",
      ],
      datasourceTemplate: "maven",
    },
    // Update the Mill executable version pinned by the wrapper.
    {
      customType: "regex",
      managerFilePatterns: ["(^|/)\\.mill-version$"],
      matchStrings: [
        "^(?<currentValue>\\S+)$",
      ],
      depNameTemplate: "com.lihaoyi:mill-dist",
      datasourceTemplate: "maven",
    },
  ],
}
